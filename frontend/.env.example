# =====================================================================
# Frontend configuration — copy this file to `.env` and adjust.
#
# Only one of the two URLs below should be active at a time. Toggle by
# commenting one line and uncommenting the other, then restart Vite.
#
# IMPORTANT: only vars prefixed with VITE_ are exposed to the client.
# =====================================================================

# --- Hosted backend (Railway / production) ---------------------------
VITE_API_BASE_URL=https://makemymock-client-production.up.railway.app/api/v1

# --- Local backend (uvicorn on port 8000) ----------------------------
# VITE_API_BASE_URL=http://localhost:8000/api/v1
