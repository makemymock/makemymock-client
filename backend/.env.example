# ===== MongoDB =====
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/
MONGO_DB_NAME=makemymock

# ===== App =====
APP_NAME=MakeMyMock
APP_ENV=development
API_V1_PREFIX=/api/v1

# ===== JWT =====
JWT_SECRET_KEY=replace-with-a-long-random-string-generated-via-secrets-token-urlsafe-64
JWT_REFRESH_SECRET_KEY=replace-with-another-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== SMTP / Email =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=youraddress@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=MakeMyMock
SMTP_USE_TLS=true

# ===== OTP =====
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
