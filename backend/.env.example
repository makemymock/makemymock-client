j# ===== MongoDB =====
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/
MONGO_DB_NAME=makemymock

# ===== App =====
APP_NAME=MakeMyMock
APP_ENV=development
API_V1_PREFIX=/api/v1

# ===== JWT =====
JWT_SECRET_KEY=replace-with-a-long-random-string-generated-via-secrets-token-urlsafe-64
JWT_REFRESH_SECRET_KEY=replace-with-another-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== SMTP / Email (used as local-dev fallback) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=youraddress@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=MakeMyMock
SMTP_USE_TLS=true

# ===== Brevo HTTPS API (recommended for Railway / Render / Vercel) =====
# Set this to use Brevo's REST API instead of SMTP. Cloud hosts often
# block outbound port 587, but Brevo's API on port 443 is always
# reachable. Leave blank to keep using SMTP (works on local dev).
# Sign up at https://brevo.com, verify your sender email (SMTP_EMAIL
# above), then copy your API key from SMTP & API → API Keys.
BREVO_API_KEY=

# ===== OTP =====
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# ===== Groq (JEE Recommender — agentic layer) =====
# Get your key at https://console.groq.com/keys
# FAST model runs per-question Question Selector (~1 s, 8B param).
# HEAVY model runs Session Planner / Diagnosis / Trend agents (async, 70B param).
# ===== JEE Questions catalog DB (adaptive_practice) =====
# The JEE Mains PYQ questions live in a separate MongoDB database on the
# same Atlas cluster, uploaded via jee_mains_pyqs_data_base/upload_to_mongo.py.
# The recommender reads from this DB without writing to it.
JEE_QUESTIONS_DB_NAME=adaptive_practice

# ===== Groq (JEE Recommender — agentic layer) =====
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_HEAVY=llama-3.3-70b-versatile
