# ===== MongoDB =====
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/
MONGO_DB_NAME=makemymock

# ===== App =====
APP_NAME=MakeMyMock
APP_ENV=development
API_V1_PREFIX=/api/v1

# ===== JWT =====
JWT_SECRET_KEY=replace-with-a-long-random-string-generated-via-secrets-token-urlsafe-64
JWT_REFRESH_SECRET_KEY=replace-with-another-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== SMTP / Email (used as local-dev fallback) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=youraddress@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=MakeMyMock
SMTP_USE_TLS=true

# ===== Brevo HTTPS API (recommended for Railway / Render / Vercel) =====
# Set this to use Brevo's REST API instead of SMTP. Cloud hosts often
# block outbound port 587, but Brevo's API on port 443 is always
# reachable. Leave blank to keep using SMTP (works on local dev).
# Sign up at https://brevo.com, verify your sender email (SMTP_EMAIL
# above), then copy your API key from SMTP & API → API Keys.
BREVO_API_KEY=

# ===== OTP =====
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# ===== SolverX — Google Vertex AI / Gemini =====
# Auth via Application Default Credentials: run `gcloud auth application-default login` once.
# Find your Project ID in GCP Console → project selector (not the project number).
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=global
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_MODEL_FLASH=gemini-2.5-flash
GEMINI_MODEL_FLASH_LITE=gemini-2.0-flash-lite
GEMINI_MODEL_DIAGRAM=gemini-2.5-flash
